echo "📝 Validating commit message..."
npx --no -- commitlint --edit "$1" || {
  echo ""
  echo "❌ Commit message validation failed!"
  echo ""
  echo "Expected format: <type>: <subject>"
  echo ""
  echo "Types: feat, fix, docs, test, refactor, chore, ci, style, perf"
  echo ""
  echo "Examples:"
  echo "  feat: add webhook system support"
  echo "  fix: resolve timeout issue in LLM client"
  echo "  docs: update configuration guide"
  echo "  test: add integration tests for cache"
  echo ""
  exit 1
}

echo "✅ Commit message is valid!"
